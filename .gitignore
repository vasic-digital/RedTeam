# CONST-053 .gitignore — digital.vasic.redteam
#
# Forbidden-from-version-control classes per the parent
# constitution submodule §11.4.30 (CONST-053).

# 1. Build artefacts
/bin/
/build/
/dist/
/out/
*.exe
*.dll
*.so
*.dylib
*.a
*.o
*.test

# 2. Cache files
.cache/
.gocache/

# 3. Temp files
*.tmp
*.swp
*~
.DS_Store
Thumbs.db
*.orig
*.rej

# 4. Sensitive-data files (CONST-042 intersection)
.env
.env.*
!.env.example
*.pem
*.key
*.crt
id_rsa*
id_ed25519*
.netrc
secrets/
api_keys.sh

# 5. Generated reports / logs
*.log
coverage.out
coverage.html
htmlcov/

# 6. OS / IDE personal state
.idea/
.history/
.vscode/
